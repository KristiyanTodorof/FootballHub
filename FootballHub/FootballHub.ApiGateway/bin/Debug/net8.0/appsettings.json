{
  "ReverseProxy": {
    "Routes": {
      "match-service-route": {
        "ClusterId": "match-service",
        "Match": {
          "Path": "/api/matches/{**catch-all}"
        }
      },
      "match-hub-route": {
        "ClusterId": "match-service",
        "Match": {
          "Path": "/hubs/matches/{**catch-all}"
        }
      },
      "league-service-route": {
        "ClusterId": "league-service",
        "Match": {
          "Path": "/api/leagues/{**catch-all}"
        }
      },
      "teams-service-route": {
        "ClusterId": "league-service",
        "Match": {
          "Path": "/api/teams/{**catch-all}"
        }
      },
      "player-service-route": {
        "ClusterId": "player-service",
        "Match": {
          "Path": "/api/players/{**catch-all}"
        }
      },
      "notification-health-route": {
        "ClusterId": "notification-service",
        "Match": {
          "Path": "/api/health/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "match-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "league-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "player-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "notification-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000"
}